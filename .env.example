# News Collector — Environment Variables
# =======================================
# Copie este arquivo como .env e preencha com seus valores reais.
# O .env está no .gitignore e NUNCA será commitado.

# Telegram Bot Token (obter em @BotFather no Telegram)
# Secret type no GitHub Actions: Telegram Bot Token
BOT_TOKEN=seu_token_aqui

# Telegram Chat ID (ID do chat/grupo onde o bot vai enviar)
# Padrão: 1585519868 (usuário Robert)
CHAT_ID=seu_chat_id_aqui

# Spotify API (opcional — para integração Spotify for Creators)
SPOTIFY_CLIENT_ID=sua_client_id_aqui
SPOTIFY_CLIENT_SECRET=sua_client_secret_aqui
